{
    "name": "power-equipment-rag-workspace",
    "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
    "runArgs": [
        "--userns=keep-id"
    ],
    "features": {},
    "postCreateCommand": "./.devcontainer/postCreateCommand.sh",
    "customizations": {
        "vscode": {
            "extensions": ["ms-python.python", "editorconfig.editorconfig"],
            "settings": {
                "python.testing.pytestArgs": ["tests"],
                "python.testing.unittestEnabled": false,
                "python.testing.pytestEnabled": true,
                "python.defaultInterpreterPath": "/workspaces/plant-graph-rag/.venv/bin/python",
                "python.testing.pytestPath": "/workspaces/plant-graph-rag/.venv/bin/pytest"
            }
        }
    }
}
