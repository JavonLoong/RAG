{
  "name": "course_knowledge_system_minimal_kg_schema",
  "version": "0.1.0",
  "scope": "Minimal graph construction schema for the Label Studio export of the marine gas turbine control and health management course paper.",
  "entity_types": [
    {
      "type": "Course",
      "description": "课程或课程体系，例如船舶燃气轮机控制与健康管理课程。"
    },
    {
      "type": "Institution",
      "description": "参与课程建设或协同育人的高校、研究所或企业。"
    },
    {
      "type": "Method",
      "description": "课程体系构建方法或教学方法，例如四维构建法。"
    },
    {
      "type": "Dimension",
      "description": "方法中的设计维度，例如知识广度、知识层次、知识深度、知识高度。"
    },
    {
      "type": "Resource",
      "description": "课程建设资源或工具，例如课程知识图谱。"
    },
    {
      "type": "Module",
      "description": "课程模块，例如动态特性分析模块、气路故障建模模块。"
    },
    {
      "type": "KnowledgePoint",
      "description": "课程知识点，例如非线性特性的线性化方法。"
    },
    {
      "type": "ScaleMetric",
      "description": "图谱规模或数量指标，例如 12 个核心模块、162 个知识点。"
    },
    {
      "type": "ApplicationScenario",
      "description": "知识图谱的教学应用场景，例如备课、上课导航、自主学习。"
    },
    {
      "type": "Outcome",
      "description": "课程建设或教学实践效果，例如学习效果提升、工程实践能力提升。"
    }
  ],
  "relation_types": [
    {
      "type": "COURSE_DEVELOPED_BY",
      "domain": ["Course"],
      "range": ["Institution"],
      "description": "课程由某机构或校企团队参与建设。"
    },
    {
      "type": "COURSE_USES_METHOD",
      "domain": ["Course"],
      "range": ["Method"],
      "description": "课程体系采用某种构建方法。"
    },
    {
      "type": "METHOD_HAS_DIMENSION",
      "domain": ["Method"],
      "range": ["Dimension"],
      "description": "方法包含某个设计维度。"
    },
    {
      "type": "COURSE_USES_RESOURCE",
      "domain": ["Course"],
      "range": ["Resource"],
      "description": "课程使用某种资源或工具。"
    },
    {
      "type": "RESOURCE_HAS_SCALE",
      "domain": ["Resource"],
      "range": ["ScaleMetric"],
      "description": "资源具有某个规模指标。"
    },
    {
      "type": "MODULE_PROVIDES_THEORY_FOR",
      "domain": ["Module"],
      "range": ["Module"],
      "description": "一个模块为另一个模块提供理论基础。"
    },
    {
      "type": "MODULE_SUPPORTS",
      "domain": ["Module"],
      "range": ["Module"],
      "description": "一个模块支撑另一个模块。"
    },
    {
      "type": "MODULE_PROVIDES_METHOD_FOR",
      "domain": ["Module"],
      "range": ["Module"],
      "description": "一个模块为另一个模块提供方法基础。"
    },
    {
      "type": "MODULE_TECHNICALLY_COMPLEMENTS",
      "domain": ["Module"],
      "range": ["Module"],
      "description": "两个模块之间存在技术互补关系。"
    },
    {
      "type": "MODULE_APPLICATION_EXTENDS_TO",
      "domain": ["Module"],
      "range": ["Module"],
      "description": "一个模块向另一个模块形成应用延伸关系。"
    },
    {
      "type": "KNOWLEDGE_POINT_METHOD_SUPPORTS",
      "domain": ["KnowledgePoint"],
      "range": ["KnowledgePoint"],
      "description": "一个知识点对另一个知识点形成方法支撑。"
    },
    {
      "type": "KNOWLEDGE_POINT_TECHNICALLY_COMPLEMENTS",
      "domain": ["KnowledgePoint"],
      "range": ["KnowledgePoint"],
      "description": "两个知识点之间存在技术互补关系。"
    },
    {
      "type": "KNOWLEDGE_POINT_PARALLEL_WITH",
      "domain": ["KnowledgePoint"],
      "range": ["KnowledgePoint"],
      "description": "两个知识点之间存在并列协同关系。"
    },
    {
      "type": "RESOURCE_USED_IN",
      "domain": ["Resource"],
      "range": ["ApplicationScenario"],
      "description": "资源应用于某个教学场景。"
    },
    {
      "type": "COURSE_HAS_OUTCOME",
      "domain": ["Course"],
      "range": ["Outcome"],
      "description": "课程建设产生某种教学或能力培养效果。"
    }
  ],
  "triple_fields": [
    "id",
    "subject",
    "subject_type",
    "predicate",
    "object",
    "object_type",
    "evidence_doc",
    "evidence_chunk_id",
    "evidence_text",
    "confidence",
    "review_status",
    "review_note"
  ],
  "review_status_values": [
    "pass",
    "needs_discussion",
    "reject"
  ]
}
