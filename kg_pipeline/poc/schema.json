{
  "name": "gas_turbine_fault_minimal_kg_schema",
  "version": "0.1.0",
  "scope": "Minimal POC schema for gas turbine / equipment fault graph construction.",
  "baseline": {
    "method": "rule-based/manual baseline",
    "llm_called": false,
    "notes": "This schema is used for a manually checked example. It does not claim automated LLM extraction has been executed."
  },
  "entity_types": [
    {
      "type": "Asset",
      "description": "设备或机组，例如 GT-07 燃气轮机。"
    },
    {
      "type": "Component",
      "description": "设备部件或子系统，例如压气机、进气滤网、温度传感器。"
    },
    {
      "type": "Fault",
      "description": "报警、故障或异常，例如压气机出口温度偏高。"
    },
    {
      "type": "Symptom",
      "description": "可观测现象，例如振动值升高。"
    },
    {
      "type": "Cause",
      "description": "可能原因，例如进气滤网堵塞、压气机叶片积灰。"
    },
    {
      "type": "Parameter",
      "description": "测量参数或阈值，例如压气机出口温度、振动值。"
    },
    {
      "type": "Sensor",
      "description": "传感器或测点，例如 VIB-CMP-01、TT-COMP-02。"
    },
    {
      "type": "Action",
      "description": "处理动作或建议，例如清理滤网、清洗叶片、校验传感器。"
    }
  ],
  "relation_types": [
    {
      "type": "HAS_COMPONENT",
      "domain": ["Asset"],
      "range": ["Component"],
      "description": "设备包含或关联某个部件。"
    },
    {
      "type": "OBSERVED_FAULT",
      "domain": ["Asset", "Component"],
      "range": ["Fault"],
      "description": "设备或部件出现某个故障/报警。"
    },
    {
      "type": "HAS_SYMPTOM",
      "domain": ["Asset", "Fault"],
      "range": ["Symptom"],
      "description": "设备或故障伴随某个现象。"
    },
    {
      "type": "POSSIBLE_CAUSE",
      "domain": ["Fault", "Symptom"],
      "range": ["Cause"],
      "description": "故障或现象的可能原因。"
    },
    {
      "type": "INDICATED_BY",
      "domain": ["Cause", "Fault", "Symptom"],
      "range": ["Parameter", "Sensor"],
      "description": "由某个参数或传感器读数指示。"
    },
    {
      "type": "MEASURED_BY",
      "domain": ["Parameter", "Symptom", "Fault"],
      "range": ["Sensor"],
      "description": "由某个传感器或测点测量。"
    },
    {
      "type": "RECOMMENDED_ACTION",
      "domain": ["Fault", "Cause", "Symptom"],
      "range": ["Action"],
      "description": "针对故障、原因或现象的建议动作。"
    },
    {
      "type": "PERFORMED_ACTION",
      "domain": ["Fault", "Cause", "Component"],
      "range": ["Action"],
      "description": "检修记录中实际执行的动作。"
    },
    {
      "type": "RESOLVED_AFTER",
      "domain": ["Fault", "Symptom"],
      "range": ["Action"],
      "description": "执行某个动作后异常恢复或缓解。"
    }
  ],
  "triple_fields": [
    "id",
    "subject",
    "subject_type",
    "predicate",
    "object",
    "object_type",
    "evidence_doc",
    "evidence_text",
    "confidence",
    "review_status",
    "review_note"
  ],
  "review_status_values": [
    "pass",
    "needs_discussion",
    "reject"
  ]
}
